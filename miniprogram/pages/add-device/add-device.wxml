<view class="page">
  <view class="panel">
    <view class="title">添加新设备</view>
    <view class="desc">点击开始后，网关会进入添加设备状态。请让 700 系列智能彩灯进入配网/入网状态。</view>
    <view class="gateway">网关：{{gateway.gatewayMac || '--'}}</view>
    <button class="primary" bindtap="startJoin">{{joining ? secondsLeft + ' 秒后结束' : '开始添加设备'}}</button>
    <view wx:if="{{errorText}}" class="error">{{errorText}}</view>
  </view>

  <view class="panel">
    <view class="row-head">
      <view class="title small">已发现设备</view>
      <button class="plain" bindtap="loadDevices">刷新</button>
    </view>
    <view wx:if="{{!devices.length}}" class="empty">暂未发现设备</view>
    <view wx:for="{{devices}}" wx:key="deviceId" class="device-row" data-id="{{item.deviceId}}" bindtap="openDevice">
      <view>
        <view class="device-name">{{item.name}}</view>
        <view class="device-meta">{{item.typeName}} · {{item.onlineText}}</view>
      </view>
      <view class="arrow">›</view>
    </view>
  </view>
</view>
