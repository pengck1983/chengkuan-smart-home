.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 28rpx;
  background: #eef5f7;
}

button::after {
  border: 0;
}

.panel {
  box-sizing: border-box;
  margin-bottom: 22rpx;
  padding: 30rpx;
  border: 1rpx solid #dbe3ee;
  border-radius: 16rpx;
  background: #ffffff;
}

.title {
  color: #172033;
  font-size: 36rpx;
  font-weight: 700;
}

.title.small {
  font-size: 30rpx;
}

.desc,
.gateway,
.empty,
.error {
  margin-top: 14rpx;
  color: #607086;
  font-size: 26rpx;
  line-height: 1.5;
}

.error {
  color: #b4233f;
}

.primary {
  width: 100%;
  height: 84rpx;
  margin-top: 28rpx;
  border-radius: 12rpx;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 84rpx;
  background: #0f766e;
}

.row-head,
.device-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.plain {
  width: 108rpx;
  height: 58rpx;
  padding: 0;
  color: #0f766e;
  font-size: 24rpx;
  line-height: 58rpx;
  background: #edf7f6;
}

.device-row {
  min-height: 112rpx;
  border-bottom: 1rpx solid #e8eef5;
}

.device-row:last-child {
  border-bottom: 0;
}

.device-name {
  color: #172033;
  font-size: 30rpx;
  font-weight: 700;
}

.device-meta {
  margin-top: 8rpx;
  color: #718096;
  font-size: 24rpx;
}

.arrow {
  color: #9aa8b8;
  font-size: 48rpx;
}
