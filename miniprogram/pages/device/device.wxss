.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 28rpx;
  background: #eef5f7;
}

button::after {
  border: 0;
}

.state-card,
.header-card,
.section {
  box-sizing: border-box;
  margin-bottom: 22rpx;
  padding: 28rpx;
  border: 1rpx solid #dbe3ee;
  border-radius: 16rpx;
  background: #ffffff;
}

.error {
  color: #b4233f;
}

.header-card {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.device-title,
.section-title {
  color: #172033;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.35;
}

.title-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.rename-button {
  width: 92rpx;
  height: 52rpx;
  padding: 0;
  border-radius: 10rpx;
  color: #0f766e;
  font-size: 23rpx;
  line-height: 52rpx;
  background: #edf7f6;
}

.device-meta,
.time-line,
.empty {
  margin-top: 10rpx;
  color: #718096;
  font-size: 25rpx;
}

.switch-row {
  display: flex;
  gap: 12rpx;
}

.round {
  width: 66rpx;
  height: 66rpx;
  padding: 0;
  border-radius: 50%;
  color: #ffffff;
  font-size: 24rpx;
  line-height: 66rpx;
}

.round.on {
  background: #0f766e;
}

.round.off {
  background: #b72945;
}

.metrics {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 22rpx;
}

.metric {
  min-height: 98rpx;
  box-sizing: border-box;
  padding: 16rpx;
  border: 1rpx solid #e1e8f0;
  border-radius: 12rpx;
  background: #f8fafc;
}

.metric-label,
.slider-label {
  color: #718096;
  font-size: 24rpx;
}

.metric-value {
  margin-top: 10rpx;
  color: #172033;
  font-size: 30rpx;
  font-weight: 700;
}

.timer-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 22rpx;
}

.time-box,
.add-timer,
.primary {
  height: 70rpx;
  box-sizing: border-box;
  padding: 0 20rpx;
  border-radius: 10rpx;
  color: #172033;
  font-size: 26rpx;
  line-height: 70rpx;
  background: #eef3f7;
}

.segmented {
  display: flex;
  overflow: hidden;
  border-radius: 10rpx;
  background: #eef3f7;
}

.segmented button,
.mode-tabs button {
  height: 70rpx;
  padding: 0 22rpx;
  border-radius: 0;
  color: #607086;
  font-size: 25rpx;
  line-height: 70rpx;
  background: transparent;
}

.segmented .active,
.mode-tabs .active {
  color: #ffffff;
  background: #0f766e;
}

.add-timer,
.primary {
  color: #ffffff;
  background: #0f766e;
}

.schedule-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 18rpx;
  color: #172033;
  font-size: 25rpx;
}

.schedule-row button {
  width: 96rpx;
  height: 56rpx;
  padding: 0;
  color: #b72945;
  font-size: 24rpx;
  line-height: 56rpx;
  background: #f7e8ec;
}

.chart-card {
  margin-top: 22rpx;
}

.chart-head {
  display: flex;
  justify-content: space-between;
  color: #172033;
  font-size: 25rpx;
}

.line-chart {
  position: relative;
  height: 150rpx;
  margin-top: 16rpx;
  overflow: hidden;
  border-radius: 12rpx;
  background: #f8fafc;
}

.y-axis {
  position: absolute;
  top: 14rpx;
  bottom: 14rpx;
  left: 12rpx;
  z-index: 2;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  color: #8a98aa;
  font-size: 20rpx;
}

.line-segment {
  position: absolute;
  height: 4rpx;
  border-radius: 4rpx;
  transform-origin: 0 50%;
  background: #0f766e;
}

.line-dot {
  position: absolute;
  width: 12rpx;
  height: 12rpx;
  margin-left: -6rpx;
  margin-top: -6rpx;
  border: 3rpx solid #ffffff;
  border-radius: 50%;
  background: #0f766e;
  box-shadow: 0 2rpx 8rpx rgba(15, 118, 110, 0.25);
}

.chart-axis,
.range-labels {
  display: flex;
  justify-content: space-between;
  margin-top: 10rpx;
  padding-left: 86rpx;
  color: #8a98aa;
  font-size: 22rpx;
}

.mode-tabs {
  display: flex;
  overflow: hidden;
  margin-top: 22rpx;
  border-radius: 12rpx;
  background: #eef3f7;
}

.mode-tabs button {
  flex: 1;
}

.slider-row {
  margin-top: 26rpx;
}

.hue-bar,
.warm-bar {
  height: 18rpx;
  margin-top: 16rpx;
  border-radius: 18rpx;
}

.hue-bar {
  background: linear-gradient(90deg, #ff3b30, #ffcc00, #34c759, #00c7ff, #5856d6, #ff2d55, #ff3b30);
}

.warm-bar {
  background: linear-gradient(90deg, #ffc36b, #fff2ce, #d7ecff);
}

.color-preview {
  width: 72rpx;
  height: 72rpx;
  margin-top: 16rpx;
  border: 6rpx solid #ffffff;
  border-radius: 50%;
  box-shadow: 0 6rpx 18rpx rgba(23, 32, 51, 0.16);
}

.send-state {
  margin-top: 24rpx;
  color: #718096;
  font-size: 24rpx;
  text-align: center;
}

.primary {
  width: 100%;
  margin-top: 28rpx;
}

.speaker-help {
  margin-top: 14rpx;
  color: #718096;
  font-size: 24rpx;
  line-height: 1.6;
}

.speaker-input {
  box-sizing: border-box;
  width: 100%;
  height: 180rpx;
  margin-top: 22rpx;
  padding: 22rpx;
  border: 2rpx solid #dbe4ed;
  border-radius: 12rpx;
  color: #172033;
  font-size: 28rpx;
  background: #f8fafc;
}

.section-subtitle {
  margin-top: 30rpx;
  color: #172033;
  font-size: 26rpx;
  font-weight: 600;
}

.speaker-tones {
  display: flex;
  gap: 14rpx;
  margin-top: 16rpx;
}

.speaker-tones button {
  flex: 1;
  padding: 0;
  color: #0f766e;
  font-size: 23rpx;
  background: #e6f4f2;
}
