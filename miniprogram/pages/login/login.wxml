<view class="login-page">
  <view class="brand">成宽智慧小家</view>
  <view class="subtitle">使用微信登录后管理你的网关和设备</view>

  <button class="login-button" loading="{{loading}}" bindtap="login">
    微信一键登录
  </button>

  <button class="guest-button" disabled="{{loading}}" bindtap="continueAsGuest">
    暂不登录，先体验
  </button>

  <view class="guest-note">无需登录即可浏览主要功能，设备绑定和控制需要登录。</view>

  <view wx:if="{{errorText}}" class="error">{{errorText}}</view>
</view>
