.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx;
  background: #f5f7fb;
}

.card {
  padding: 32rpx;
  border: 1rpx solid #dbe3ee;
  border-radius: 8rpx;
  background: #ffffff;
}

.title {
  color: #172033;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.4;
}

.desc {
  margin-top: 16rpx;
  color: #607086;
  font-size: 26rpx;
  line-height: 1.6;
}

.field {
  margin-top: 32rpx;
}

.label {
  color: #344256;
  font-size: 26rpx;
  font-weight: 700;
}

.input {
  margin-top: 12rpx;
  height: 80rpx;
  box-sizing: border-box;
  padding: 0 20rpx;
  border: 1rpx solid #dbe3ee;
  border-radius: 8rpx;
  color: #172033;
  font-size: 28rpx;
  background: #f8fafc;
}

.button-row {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

button {
  flex: 1;
  height: 78rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 78rpx;
}

button::after {
  border: 0;
}

.primary {
  color: #ffffff;
  background: #0f766e;
}

.secondary {
  color: #172033;
  background: #e3e9f2;
}

.error {
  margin-top: 24rpx;
  color: #b4233f;
  font-size: 26rpx;
  line-height: 1.5;
}
