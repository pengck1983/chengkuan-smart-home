.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 28rpx;
  background: #eef5f7;
}

button::after {
  border: 0;
}

.profile-card,
.panel,
.guest-panel {
  box-sizing: border-box;
  margin-bottom: 22rpx;
  padding: 30rpx;
  border: 1rpx solid #dbe3ee;
  border-radius: 16rpx;
  background: #ffffff;
}

.guest-panel {
  text-align: center;
}

.guest-avatar {
  margin: 8rpx auto 22rpx;
  background: #718096;
}

.guest-sub {
  margin: 18rpx auto 0;
  max-width: 560rpx;
  line-height: 1.6;
}

.login-action {
  width: 100%;
  height: 82rpx;
  margin-top: 32rpx;
  border-radius: 10rpx;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 82rpx;
  background: #0f766e;
}

.profile-card {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 88rpx;
  text-align: center;
  background: #0f766e;
}

.name,
.panel-title {
  color: #172033;
  font-size: 32rpx;
  font-weight: 700;
}

.sub {
  margin-top: 8rpx;
  color: #718096;
  font-size: 24rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #e8eef5;
  color: #607086;
  font-size: 26rpx;
}

.info-row text:last-child {
  color: #172033;
}

.secondary,
.logout {
  width: 100%;
  height: 78rpx;
  margin-top: 28rpx;
  border-radius: 12rpx;
  font-size: 27rpx;
  line-height: 78rpx;
}

.secondary {
  color: #0f766e;
  background: #edf7f6;
}

.logout {
  color: #b72945;
  background: #f7e8ec;
}
