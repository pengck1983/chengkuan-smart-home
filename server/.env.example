PORT=3000
MCP_API_PORT=3001
MCP_BRIDGE_SECRET=GENERATE_A_DIFFERENT_RANDOM_SECRET

# EMQX MQTT/TLS endpoint for gateways and business server.
MQTT_URL=mqtts://YOUR_EMQX_HOST:8883
MQTT_USERNAME=YOUR_MQTT_USERNAME
MQTT_PASSWORD=YOUR_MQTT_PASSWORD

# Optional. Use only if your MQTT broker requires a custom CA file.
# MQTT_CA_FILE=C:\chengkuan-iot\certs\emqx-ca.crt

# Initial gateway for the first deployment.
DEFAULT_GATEWAY_MAC=YOUR_GATEWAY_MAC
DEFAULT_HOME_NAME=成宽智慧小家

# Very small first-version auth secret. Change before public deployment.
APP_TOKEN_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# Required for real WeChat login. Keep these only on the server.
WECHAT_APPID=YOUR_MINIPROGRAM_APPID
WECHAT_APPSECRET=YOUR_MINIPROGRAM_APPSECRET

# Meter-socket power alarm. The UIID 1400 speaker announces when power reaches
# the threshold and rearms after power falls below the reset value.
POWER_ALARM_WATTS=600
POWER_ALARM_RESET_WATTS=500
POWER_ALARM_COOLDOWN_MS=60000
